generator client {
  provider      = "prisma-client-js"
  output        = "../client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  email         String     @unique
  phone         String     @unique
  employeeId    String     @unique
  name          String
  department    String?
  role          Role       @default(EMPLOYEE)
  passwordHash  String?
  isVerified    Boolean    @default(false)
  otp           String?
  otpExpiry     DateTime?
  college       String?
  gradYear      String?
  bio           String?
  location      String?
  createdAt     DateTime   @default(now())
  
  // Real-time Referral Networking
  referredById  String?    @db.ObjectId
  referredBy    User?      @relation("UserReferral", fields: [referredById], references: [id], onUpdate: NoAction, onDelete: NoAction)
  referredUsers User[]     @relation("UserReferral")
  
  referrals     Referral[]
}

model OtpVerification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailLog {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  to      String
  subject String
  body    String
  otp     String?
  sentAt  DateTime @default(now())
  status  String   @default("SENT")
}

model Referral {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  refCode        String      @unique @default(cuid())
  candidateName  String
  candidateEmail String
  candidatePhone String
  resumeUrl      String?
  notes          String?
  college        String?
  gradYear       String?
  bio            String?
  location       String?
  status         ReferralStatus @default(NEW)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  referredById   String      @db.ObjectId
  positionId     String      @db.ObjectId
  position       Position    @relation(fields: [positionId], references: [id])
  referredBy     User        @relation(fields: [referredById], references: [id])
  statusHistory  StatusLog[]
}

model StatusLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  fromStatus ReferralStatus
  toStatus   ReferralStatus
  note       String?
  createdAt  DateTime @default(now())
  referralId String @db.ObjectId
  changedBy  String
  referral   Referral @relation(fields: [referralId], references: [id])
}

model Position {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  title      String     @unique
  department String?
  location   String?
  isActive   Boolean    @default(true)
  referrals  Referral[]
}

enum Role {
  EMPLOYEE
  ADMIN
  HR
  CLUB_HEADER
}

enum ReferralStatus {
  NEW
  CONTACTED
  SELECTED
  REJECTED
}
